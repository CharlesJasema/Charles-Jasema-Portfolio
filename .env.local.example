# Google Analytics
# Get your Measurement ID from https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Flutterwave (Mobile Money Donations)
# Get your payment link from https://dashboard.flutterwave.com
# Format: https://flutterwave.com/pay/your-payment-link
NEXT_PUBLIC_FLUTTERWAVE_LINK=

# PayPal (International Donations)
# Get your donate button link from https://www.paypal.com/donate/buttons
# Format: https://www.paypal.com/donate/?hosted_button_id=XXXXXXXXX
NEXT_PUBLIC_PAYPAL_LINK=

# Newsletter/Email Service (Optional)
# Mailchimp API Key (if using Mailchimp)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=

# ConvertKit API Key (if using ConvertKit)
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=
