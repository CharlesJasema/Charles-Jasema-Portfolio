# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token
SANITY_REVALIDATION_SECRET=your-revalidation-secret

# Analytics Configuration
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Tawk.to Live Chat Configuration
NEXT_PUBLIC_TAWK_TO_PROPERTY_ID=your-tawk-property-id
NEXT_PUBLIC_TAWK_TO_WIDGET_ID=your-tawk-widget-id

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://charlesjasema.com
NEXT_PUBLIC_SITE_NAME=Charles Jasema Portfolio
NEXT_PUBLIC_SITE_DESCRIPTION=Professional portfolio of Charles Jasema - Software Engineer, Designer & Gospel Artist

# Security Configuration
CSRF_SECRET=your-csrf-secret-key-here
RATE_LIMIT_SECRET=your-rate-limit-secret-here

# Email Service Configuration (Multi-Provider Support)
# Contact email for receiving form submissions
CONTACT_EMAIL=contact@charlesjasema.com

# Default sender configuration
FROM_EMAIL=noreply@charlesjasema.com
FROM_NAME=Charles Jasema
REPLY_TO_EMAIL=contact@charlesjasema.com

# Email service settings
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=1000
EMAIL_TIMEOUT=30000

# SendGrid Provider (Priority 1)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@charlesjasema.com

# Resend Provider (Priority 2)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@charlesjasema.com

# AWS SES Provider (Priority 3)
AWS_SES_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SES_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@charlesjasema.com

# Legacy SMTP Configuration (Deprecated - use providers above)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Social Media Configuration
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/charlesjasema
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/charlesjasema
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/charlesjasema
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/charlesjasema
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@charlesjasema
NEXT_PUBLIC_GITHUB_URL=https://github.com/charlesjasema

# Production Configuration
NODE_ENV=production